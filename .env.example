# Memory MCP Triple System - Environment Variables
# Copy this file to .env and fill in your values

# NOTE: v5.0+ uses embedded databases (ChromaDB, NetworkX)
# No database passwords required for single-user deployment

# MCP Server
# Set one of these to a real secret before using HTTP tools or a public tunnel.
# MCP_API_KEY=
# MEMORY_MCP_API_KEY=

# HTTP server bind settings
# Defaults to 127.0.0.1 for local safety. Railway/container deployments may set 0.0.0.0.
# MEMORY_MCP_HTTP_HOST=127.0.0.1
# MEMORY_MCP_HTTP_PORT=8080

# Public tunnel settings
# Public tunnel startup scripts refuse to run unless this is explicitly true and an API key is set.
# MEMORY_MCP_ENABLE_PUBLIC_TUNNEL=false

# Optional: Model API Keys (if using cloud models)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GOOGLE_API_KEY=your_google_key_here

# Data Storage (defaults to ./data if not set)
# MEMORY_MCP_DATA_DIR=~/.memory-mcp/data
# CHROMA_PERSIST_DIR=~/.memory-mcp/data/chroma

# Local ops paths
# CLAUDE_HOME=~/.claude

# HuggingFace Cache (defaults to ~/.cache/huggingface if not set)
# HF_HOME=~/.cache/huggingface

# Optional: Obsidian Integration
# OBSIDIAN_VAULT_PATH=~/Documents/Obsidian Vault

# Development Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
